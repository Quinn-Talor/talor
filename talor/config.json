{
  "$schema": "https://talor.dev/schemas/config-1.0.0.json",
  "default_agent": "build",
  "default_model": "ollama/qwen3:4b",

  "agent": {
    "code-review": {
      "description": "Code review agent. Analyzes code for issues, suggests improvements, and checks best practices.",
      "mode": "subagent",
      "prompt": ".talor/prompts/code-review.md",
      "model": {
        "provider_id": "ollama",
        "model_id": "deepseek-v3.1:671b-cloud"
      },
      "temperature": 0.3,
      "steps": 30,
      "permission": {
        "*": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "ls": "allow"
      },
      "plugins": {
        "skill": { "enabled": false },
        "code_review_rules": {
          "enabled": true,
          "path": ".talor/plugins/code_review_rules.py"
        }
      }
    }
  },

  "providers": {
    "ollama": {
      "name": "Ollama",
      "api_key_env": null,
      "base_url": "http://localhost:11434/v1",
      "auto_discover": true,
      "models": []
    }
  },

  "mcp": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"],
      "env": {},
      "disabled": false,
      "auto_approve": []
    },
    "pymupdf4llm-mcp": {
      "command": "uvx",
      "args": ["pymupdf4llm-mcp@latest", "stdio"],
      "env": {},
      "disabled": false,
      "auto_approve": []
    }
  },

  "permission": {
    "*": "allow",
    "bash": "ask",
    "write": "ask",
    "edit": "ask",
    "read": {
      "*": "allow",
      "*.env": "ask",
      "*.env.*": "ask",
      "*.env.example": "allow"
    }
  },

  "plugins": {
    "project_rules": {
      "enabled": true,
      "priority": 1000,
      "path": ".talor/plugins/project_rules.py"
    }
  },

  "workspace": [],

  "instructions": [],

  "keybinds": {},

  "experimental": {},

  "username": null
}
