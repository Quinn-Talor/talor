{
  "default_model": "ollama/deepseek-v3.1:671b-cloud",
  "provider": {
    "ollama": {
      "api_key": "ollama",
      "base_url": "http://localhost:11434/v1"
    }
  },
  "mcp": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"],
      "transport": "stdio"
    },
    "pymupdf4llm-mcp": {
      "command": "uvx",
      "args": ["pymupdf4llm-mcp@latest", "stdio"],
      "env": {}
    }
  },
  "permissions": {
    "rules": [
      {
        "tool_pattern": "read_*",
        "action": "allow",
        "scope": "always"
      },
      {
        "tool_pattern": "write_*",
        "action": "ask",
        "scope": "session"
      }
    ],
    "dangerous_operations": [
      "delete_file",
      "write_file",
      "execute_command"
    ]
  },
  "logging": {
    "level": "INFO"
  },
  "ui": {
    "theme": "dark",
    "font_size": 14
  }
}
