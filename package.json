{
  "name": "talor-desktop",
  "version": "0.1.0",
  "description": "Talor Desktop - AI Agent Platform",
  "type": "module",
  "main": "./out/main/index.js",
  "author": "Talor",
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck:main": "tsc --noEmit -p tsconfig.main.json",
    "typecheck:preload": "tsc --noEmit -p tsconfig.preload.json",
    "typecheck:renderer": "tsc --noEmit -p tsconfig.json",
    "typecheck": "npm run typecheck:main && npm run typecheck:preload && npm run typecheck:renderer",
    "rebuild:electron": "electron-builder install-app-deps",
    "rebuild:node": "npm rebuild better-sqlite3 --build-from-source",
    "postinstall": "npm run rebuild:electron",
    "predev": "npm run rebuild:electron",
    "prebuild": "npm run rebuild:electron",
    "test": "npm run rebuild:node && (vitest run; rc=$?; npm run rebuild:electron; exit $rc)",
    "test:watch": "npm run rebuild:node && vitest",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.0",
    "@ai-sdk/google": "^4.0.1",
    "@ai-sdk/openai": "^4.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "ai": "^7.0.3",
    "ajv": "^8.20.0",
    "better-sqlite3": "^12.8.0",
    "electron-log": "^5.2.4",
    "electron-store": "^11.0.2",
    "jsonc-parser": "^3.3.1",
    "ollama-ai-provider-v2": "^3.5.0",
    "p-limit": "^6.2.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "semver": "^7.7.4",
    "uuid": "^14.0.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^10.0.1",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.6",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/semver": "^7.7.1",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "chrome-remote-interface": "^0.34.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.3",
    "prettier": "^3.8.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "zustand": "^5.0.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,html,css}": [
      "prettier --write"
    ]
  }
}
