    "ai": "^6.0.134",
    "better-sqlite3": "^12.8.0",
    "electron-log": "^5.2.4",
    "electron-store": "^10.0.0",
    "ollama-ai-provider-v2": "^3.5.0",
    "react-markdown": "^10.1.0",
